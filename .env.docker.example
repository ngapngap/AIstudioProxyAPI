# Docker Environment Configuration Example
# Copy this file to .env and configure as needed

# =============================================================================
# Docker Host Configuration
# =============================================================================

# Image name (default: ghcr.io/NukerXB/AIstudioProxyAPI)
IMAGE_NAME=NukerXB/AIstudioProxyAPI

# Host ports (external access)
HOST_FASTAPI_PORT=2048
HOST_STREAM_PORT=3120

# =============================================================================
# Container Service Ports
# =============================================================================

PORT=8000
DEFAULT_FASTAPI_PORT=2048
DEFAULT_CAMOUFOX_PORT=9222
STREAM_PORT=3120

# =============================================================================
# Proxy Configuration
# =============================================================================

HTTP_PROXY=
HTTPS_PROXY=
UNIFIED_PROXY_CONFIG=
NO_PROXY=localhost;127.0.0.1;*.local

# =============================================================================
# Logging
# =============================================================================

SERVER_LOG_LEVEL=INFO
SERVER_REDIRECT_PRINT=false
DEBUG_LOGS_ENABLED=false
TRACE_LOGS_ENABLED=false

# =============================================================================
# Authentication
# =============================================================================

AUTO_SAVE_AUTH=false
AUTH_SAVE_TIMEOUT=30
AUTO_CONFIRM_LOGIN=true

# =============================================================================
# Browser
# =============================================================================

LAUNCH_MODE=headless

# =============================================================================
# API Defaults
# =============================================================================

DEFAULT_TEMPERATURE=1.0
DEFAULT_MAX_OUTPUT_TOKENS=65536
DEFAULT_TOP_P=0.95
DEFAULT_STOP_SEQUENCES=["User:"]

# =============================================================================
# Timeouts (ms)
# =============================================================================

RESPONSE_COMPLETION_TIMEOUT=300000
POLLING_INTERVAL=300
POLLING_INTERVAL_STREAM=180
SILENCE_TIMEOUT_MS=60000

# =============================================================================
# Script Injection
# =============================================================================

ENABLE_SCRIPT_INJECTION=false
USERSCRIPT_PATH=browser_utils/more_models.js

# =============================================================================
# Docker Resource Limits
# =============================================================================

# DOCKER_MEMORY_LIMIT=1g
# DOCKER_MEMSWAP_LIMIT=